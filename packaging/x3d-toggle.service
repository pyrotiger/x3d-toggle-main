[Unit]
Description=AMD x3D V-Cache Optimizer Daemon
Documentation=https://github.com/pyrotiger/x3d-toggle-main
After=multi-user.target
Wants=systemd-modules-load.service
StartLimitIntervalSec=0

[Service]
Type=notify
ExecStart=/usr/bin/x3d-daemon
Restart=on-failure
RestartSec=10
MemoryAccounting=yes

RuntimeDirectory=x3d-toggle
RuntimeDirectoryMode=2770
Group=x3d-toggle
User=x3d-toggle
LimitMEMLOCK=infinity
LimitCORE=infinity

AmbientCapabilities=CAP_SYS_ADMIN CAP_PERFMON CAP_BPF CAP_SYS_NICE CAP_DAC_READ_SEARCH
CapabilityBoundingSet=CAP_SYS_ADMIN CAP_PERFMON CAP_BPF CAP_SYS_NICE CAP_DAC_READ_SEARCH

ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes
ProtectKernelModules=yes
ProtectControlGroups=no
ProtectKernelTunables=no
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
RestrictRealtime=no

SystemCallArchitectures=native
RestrictSUIDSGID=yes

ReadWritePaths=/sys/devices/system/cpu
ReadWritePaths=/sys/fs/bpf
ReadWritePaths=/sys/fs/cgroup
ReadWritePaths=/sys/devices/platform
ReadWritePaths=/sys/bus/platform/drivers/amd_x3d_vcache
ReadWritePaths=/run/x3d-toggle
ReadWritePaths=/etc/x3d-toggle.d
ReadWritePaths=/var/log/x3d-toggle
ReadWritePaths=/proc/sys/kernel

ExecStopPost=/usr/bin/x3d-toggle journal-dump ; /usr/bin/x3d-toggle journal-archive

[Install]
WantedBy=multi-user.target

## Daemon Permissions Elevation for the X3D Toggle Project: `x3d-toggle.service`
## Least Privilege: Ambient capabilities granted at exec, NoNewPrivileges enforced.
## All paths pre-provisioned by tmpfiles.conf with correct group ownership.
## end of file
