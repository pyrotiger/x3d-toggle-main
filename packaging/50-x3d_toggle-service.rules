polkit.addRule(function(action, subject) {
    if (subject.isInGroup("x3d-toggle")) {

        if (action.id == "org.freedesktop.policykit.exec") {
            var program = action.lookup("program");
            if (program == "/usr/bin/x3d-toggle" ||
                program == "/usr/bin/x3d" ||
                program == "/usr/bin/x3d-daemon" ||
                program == "/usr/bin/x3d-run" ||
                program == "/usr/bin/x3d-gui") {
                return polkit.Result.YES;
            }
        }

        if (action.id == "org.freedesktop.systemd1.manage-units") {
            if (action.lookup("unit") == "x3d-toggle.service") {
                return polkit.Result.YES;
            }
        }

        /* systemd does not pass unit names in action details for
         * manage-unit-files; only the verb (enable/disable/etc) is
         * available. Scoping to the x3d-toggle group is sufficient
         * isolation for passwordless enable/disable. */
        if (action.id == "org.freedesktop.systemd1.manage-unit-files") {
            return polkit.Result.YES;
        }

        if (action.id == "org.freedesktop.systemd1.reload-daemon") {
            return polkit.Result.YES;
        }
    }
});

/* Polkit rules for the X3D Toggle Project: `50-x3d_toggle-service.rules`
 * Granting permissions to the 'x3d-toggle' group for 
 * topology management and service control.
 */

