<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="adw" version="1.0"/>
  
  <object class="AdwApplicationWindow" id="main_window">
    <property name="title">X3D Toggle Dashboard</property>
    <property name="default-width">960</property>
    <property name="default-height">680</property>
    
    <property name="content">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        
        <child>
          <object class="AdwHeaderBar">
            <property name="title-widget">
              <object class="GtkLabel">
                <property name="label">X3D Toggle Dashboard</property>
                <style>
                  <class name="x3d-accent"/>
                </style>
              </object>
            </property>
          </object>
        </child>

        <child>
          <object class="AdwNavigationSplitView">
            <property name="sidebar">
              <object class="AdwNavigationPage">
                <property name="title">Menu</property>
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="child">
                      <object class="GtkListBox" id="sidebar_list">
                        <property name="selection-mode">single</property>
                        <style>
                          <class name="navigation-sidebar"/>
                        </style>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </property>

            <property name="content">
              <object class="AdwNavigationPage">
                <property name="title">Content</property>
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="child">
                      <object class="GtkStack" id="content_stack">
                        <property name="transition-type">crossfade</property>
                        <property name="margin-start">24</property>
                        <property name="margin-end">24</property>
                        <property name="margin-top">16</property>
                        <property name="margin-bottom">16</property>
                        
                        <!-- Dashboard Page -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <style>
                                  <class name="x3d-hero"/>
                                </style>
                                <child>
                                  <object class="GtkImage">
                                    <property name="resource">/org/x3d-toggle/gui/x3d-toggle.jpg</property>
                                    <property name="pixel-size">120</property>
                                    <property name="halign">center</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">RYZEN X3D Toggle</property>
                                    <style><class name="x3d-hero-title"/></style>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <!-- Live Data Card -->
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <style><class name="x3d-card"/></style>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">DAEMON TELEMETRY</property>
                                    <style><class name="x3d-card-title"/></style>
                                    <property name="halign">start</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="lbl_status_dump">
                                    <property name="label">Connecting to daemon...</property>
                                    <style><class name="x3d-value"/></style>
                                    <property name="halign">start</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                          <property name="name">dashboard</property>
                        </child>

                        <!-- Hardware Modes Page -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Hardware Modes</property>
                                <style><class name="x3d-hero-title"/></style>
                                <property name="halign">start</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkGrid">
                                <property name="row-spacing">12</property>
                                <property name="column-spacing">12</property>
                                <property name="column-homogeneous">true</property>
                                
                                <!-- Cache -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <style><class name="x3d-mode-card"/></style>
                                    <child><object class="GtkLabel"><property name="label">Cache</property><style><class name="x3d-accent"/></style><property name="halign">start</property></object></child>
                                    <child><object class="GtkLabel"><property name="label">Prioritize 3D V-Cache CCD</property><style><class name="x3d-dim"/></style><property name="halign">start</property></object></child>
                                    <child><object class="GtkButton" id="action_x3dtoggle_cache"><property name="label">Apply</property><style><class name="x3d-primary"/></style><property name="halign">end</property></object></child>
                                  </object>
                                  <layout>
                                    <property name="column">0</property>
                                    <property name="row">0</property>
                                  </layout>
                                </child>
                                
                                <!-- Frequency -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <style><class name="x3d-mode-card"/></style>
                                    <child><object class="GtkLabel"><property name="label">Frequency</property><style><class name="x3d-accent"/></style><property name="halign">start</property></object></child>
                                    <child><object class="GtkLabel"><property name="label">Prioritize frequency cores</property><style><class name="x3d-dim"/></style><property name="halign">start</property></object></child>
                                    <child><object class="GtkButton" id="action_x3dtoggle_frequency"><property name="label">Apply</property><style><class name="x3d-primary"/></style><property name="halign">end</property></object></child>
                                  </object>
                                  <layout>
                                    <property name="column">1</property>
                                    <property name="row">0</property>
                                  </layout>
                                </child>

                                <!-- Dual -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <style><class name="x3d-mode-card"/></style>
                                    <child><object class="GtkLabel"><property name="label">Dual</property><style><class name="x3d-accent"/></style><property name="halign">start</property></object></child>
                                    <child><object class="GtkLabel"><property name="label">Maximize throughput across CCDs</property><style><class name="x3d-dim"/></style><property name="halign">start</property></object></child>
                                    <child><object class="GtkButton" id="action_x3dtoggle_dual"><property name="label">Apply</property><style><class name="x3d-primary"/></style><property name="halign">end</property></object></child>
                                  </object>
                                  <layout>
                                    <property name="column">0</property>
                                    <property name="row">1</property>
                                  </layout>
                                </child>

                                <!-- Default -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <style><class name="x3d-mode-card"/></style>
                                    <child><object class="GtkLabel"><property name="label">Default</property><style><class name="x3d-accent"/></style><property name="halign">start</property></object></child>
                                    <child><object class="GtkLabel"><property name="label">Restore daemon default</property><style><class name="x3d-dim"/></style><property name="halign">start</property></object></child>
                                    <child><object class="GtkButton" id="action_x3dtoggle_default"><property name="label">Apply</property><style><class name="x3d-primary"/></style><property name="halign">end</property></object></child>
                                  </object>
                                  <layout>
                                    <property name="column">1</property>
                                    <property name="row">1</property>
                                  </layout>
                                </child>

                              </object>
                            </child>
                          </object>
                          <property name="name">modes</property>
                        </child>

                        <!-- Daemon Controls -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Daemon Lifecycle</property>
                                <style><class name="x3d-hero-title"/></style>
                                <property name="halign">start</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwPreferencesGroup">
                                <!-- Wake -->
                                <child>
                                  <object class="AdwActionRow">
                                    <property name="title">Wake</property>
                                    <property name="subtitle">Refresh state loop via IPC</property>
                                    <child type="suffix">
                                      <object class="GtkButton" id="action_x3dtoggle_wake">
                                        <property name="label">Wake</property>
                                        <style><class name="x3d-primary"/></style>
                                        <property name="valign">center</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <!-- Sleep -->
                                <child>
                                  <object class="AdwActionRow">
                                    <property name="title">Sleep</property>
                                    <property name="subtitle">Suspend daemon logic loop</property>
                                    <child type="suffix">
                                      <object class="GtkButton" id="action_x3dtoggle_sleep">
                                        <property name="label">Sleep</property>
                                        <style><class name="x3d-primary"/></style>
                                        <property name="valign">center</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <!-- Stop -->
                                <child>
                                  <object class="AdwActionRow">
                                    <property name="title">Stop</property>
                                    <property name="subtitle">Kill daemon gracefully</property>
                                    <child type="suffix">
                                      <object class="GtkButton" id="action_x3dtoggle_stop">
                                        <property name="label">Stop</property>
                                        <style><class name="x3d-destructive"/></style>
                                        <property name="valign">center</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <!-- Enable -->
                                <child>
                                  <object class="AdwActionRow">
                                    <property name="title">Enable</property>
                                    <property name="subtitle">Start daemon (no autostart)</property>
                                    <child type="suffix">
                                      <object class="GtkButton" id="action_x3dtoggle_enable">
                                        <property name="label">Enable</property>
                                        <style><class name="x3d-primary"/></style>
                                        <property name="valign">center</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <!-- Start -->
                                <child>
                                  <object class="AdwActionRow">
                                    <property name="title">Start</property>
                                    <property name="subtitle">Start daemon and autostart</property>
                                    <child type="suffix">
                                      <object class="GtkButton" id="action_x3dtoggle_start">
                                        <property name="label">Start</property>
                                        <style><class name="x3d-primary"/></style>
                                        <property name="valign">center</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                          <property name="name">daemon</property>
                        </child>

                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </child>

      </object>
    </property>
  </object>
</interface>
