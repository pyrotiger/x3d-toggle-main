<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="adw" version="1.0"/>
  
  <object class="AdwApplicationWindow" id="main_window">
    <property name="title">X3D Toggle Dashboard</property>
    <property name="default-width">960</property>
    <property name="default-height">680</property>
    
    <property name="content">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        
        <child>
          <object class="AdwHeaderBar">
            <property name="title-widget">
              <object class="GtkLabel">
                <property name="label">X3D Toggle Dashboard</property>
                <style>
                  <class name="x3d-accent"/>
                </style>
              </object>
            </property>
          </object>
        </child>

        <child>
          <object class="AdwNavigationSplitView">
            <property name="sidebar">
              <object class="AdwNavigationPage">
                <property name="title">Menu</property>
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="margin-top">12</property>
                    <property name="margin-bottom">12</property>
                    <style>
                      <class name="navigation-sidebar"/>
                    </style>

                    <child>
                      <object class="GtkListBox" id="sidebar_list">
                        <property name="selection-mode">single</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="vexpand">true</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkListBox" id="sidebar_bottom_list">
                        <property name="selection-mode">single</property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </property>

            <property name="content">
              <object class="AdwNavigationPage">
                <property name="title">Content</property>
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="child">
                      <object class="GtkStack" id="content_stack">
                        <property name="transition-type">crossfade</property>
                        <property name="margin-start">24</property>
                        <property name="margin-end">24</property>
                        <property name="margin-top">16</property>
                        <property name="margin-bottom">16</property>
                        
                        <!-- Dashboard Page -->
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">dashboard</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <style>
                                      <class name="x3d-hero"/>
                                    </style>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="resource">/org/x3d-toggle/gui/x3d-toggle.jpg</property>
                                        <property name="pixel-size">120</property>
                                        <property name="halign">center</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">RYZEN X3D Toggle</property>
                                        <style><class name="x3d-hero-title"/></style>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <!-- Live Data Card (Main Summary) -->
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <style><class name="x3d-card"/></style>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">DAEMON TELEMETRY</property>
                                    <style><class name="x3d-card-title"/></style>
                                    <property name="halign">start</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="lbl_status_dump">
                                    <property name="label">Connecting to daemon...</property>
                                    <style><class name="x3d-value"/></style>
                                    <property name="halign">start</property>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <!-- Status Indicators -->
                            <child>
                              <object class="AdwPreferencesGroup">
                                <property name="title">Status Indicators</property>
                                
                                <child>
                                  <object class="AdwActionRow" id="nav_daemon_status">
                                    <property name="title">Daemon Status</property>
                                    <property name="subtitle">State, IPC, eBPF, Scheduler</property>
                                    <property name="activatable">true</property>
                                    <child type="prefix">
                                      <object class="GtkImage">
                                        <property name="icon-name">system-run-symbolic</property>
                                      </object>
                                    </child>
                                    <child type="suffix">
                                      <object class="GtkImage">
                                        <property name="icon-name">go-next-symbolic</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="AdwActionRow" id="nav_vcache_status">
                                    <property name="title">v-Cache Status</property>
                                    <property name="subtitle">Mode, Boost, CCD Status</property>
                                    <property name="activatable">true</property>
                                    <child type="prefix">
                                      <object class="GtkImage">
                                        <property name="icon-name">processor-symbolic</property>
                                      </object>
                                    </child>
                                    <child type="suffix">
                                      <object class="GtkImage">
                                        <property name="icon-name">go-next-symbolic</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="AdwActionRow" id="nav_cppc_status">
                                    <property name="title">CPPC Status</property>
                                    <property name="subtitle">Driver, EPP, Governor, SMT</property>
                                    <property name="activatable">true</property>
                                    <child type="prefix">
                                      <object class="GtkImage">
                                        <property name="icon-name">preferences-system-performance-symbolic</property>
                                      </object>
                                    </child>
                                    <child type="suffix">
                                      <object class="GtkImage">
                                        <property name="icon-name">go-next-symbolic</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                            </property>
                          </object>
                        </child>

                        <!-- Settings Page -->
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">settings</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">18</property>
                                
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">Hardware Modes</property>
                                    <style><class name="x3d-hero-title"/></style>
                                    <property name="halign">start</property>
                                  </object>
                                </child>

                                <child>
                                  <object class="GtkBox">
                                    <property name="spacing">12</property>
                                    <property name="homogeneous">true</property>
                                    
                                    <!-- Cache -->
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <style><class name="x3d-mode-card"/></style>
                                        <child><object class="GtkLabel"><property name="label">Cache</property><style><class name="x3d-accent"/></style><property name="halign">start</property></object></child>
                                        <child><object class="GtkLabel"><property name="label">Prioritize 3D V-Cache CCD</property><style><class name="x3d-dim"/></style><property name="halign">start</property></object></child>
                                        <child><object class="GtkButton" id="action_x3dtoggle_cache"><property name="label">Apply</property><style><class name="x3d-primary"/></style><property name="halign">end</property></object></child>
                                      </object>
                                    </child>
                                    
                                    <!-- Frequency -->
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <style><class name="x3d-mode-card"/></style>
                                        <child><object class="GtkLabel"><property name="label">Frequency</property><style><class name="x3d-accent"/></style><property name="halign">start</property></object></child>
                                        <child><object class="GtkLabel"><property name="label">Prioritize frequency cores</property><style><class name="x3d-dim"/></style><property name="halign">start</property></object></child>
                                        <child><object class="GtkButton" id="action_x3dtoggle_frequency"><property name="label">Apply</property><style><class name="x3d-primary"/></style><property name="halign">end</property></object></child>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">Daemon Lifecycle</property>
                                    <style><class name="x3d-hero-title"/></style>
                                    <property name="halign">start</property>
                                    <property name="margin-top">12</property>
                                  </object>
                                <!-- Daemon Status Detail Page -->
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">daemon_status_page</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="AdwPreferencesGroup">
                                    <property name="title">Daemon Status Details</property>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">Daemon State</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_daemon_state"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">IPC State</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_ipc_status"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">eBPF Health</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_ebpf_status"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">Scheduler Mode</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_sched_mode"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="btn_back_daemon">
                                    <property name="label">Back to Dashboard</property>
                                    <property name="halign">start</property>
                                    <style><class name="flat"/></style>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>

                        <!-- v-Cache Status Detail Page -->
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">vcache_status_page</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="AdwPreferencesGroup">
                                    <property name="title">v-Cache Status Details</property>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">v-Cache Mode</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_vcache_mode"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">Boost Mode</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_boost_mode"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">CCD Status</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_ccd_status"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="btn_back_vcache">
                                    <property name="label">Back to Dashboard</property>
                                    <property name="halign">start</property>
                                    <style><class name="flat"/></style>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>

                        <!-- CPPC Status Detail Page -->
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">cppc_status_page</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="AdwPreferencesGroup">
                                    <property name="title">CPPC Status Details</property>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">Driver Mode</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_driver_mode"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">EPP Profile</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_epp_profile"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">Governor / Profile</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_cppc_gov"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">SMT Status</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_smt_status"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">Platform</property>
                                        <child type="suffix"><object class="GtkLabel" id="lbl_stat_platform"><property name="label">N/A</property><style><class name="x3d-accent"/></style></object></child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="btn_back_cppc">
                                    <property name="label">Back to Dashboard</property>
                                    <property name="halign">start</property>
                                    <style><class name="flat"/></style>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>

                                <child>
                                  <object class="AdwPreferencesGroup">
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">Sleep</property>
                                        <property name="subtitle">Suspend daemon logic loop</property>
                                        <child type="suffix">
                                          <object class="GtkButton" id="action_x3dtoggle_sleep"><property name="label">Sleep</property><style><class name="x3d-primary"/></style></object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwActionRow">
                                        <property name="title">Stop</property>
                                        <property name="subtitle">Kill daemon gracefully</property>
                                        <child type="suffix">
                                          <object class="GtkButton" id="action_x3dtoggle_stop"><property name="label">Stop</property><style><class name="x3d-destructive"/></style></object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>

                        <!-- Documentation Page -->
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">docs</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">Documentation</property>
                                    <style><class name="x3d-hero-title"/></style>
                                    <property name="halign">start</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">X3D Toggle ensures your Ryzen processor always uses the optimal CCD for your current workload.

&lt;b&gt;Manual Mode:&lt;/b&gt; You control which CCD is preferred.
&lt;b&gt;Auto Mode:&lt;/b&gt; The daemon detects games and adjusts affinity automatically.</property>
                                    <property name="use-markup">true</property>
                                    <property name="wrap">true</property>
                                    <property name="halign">start</property>
                                    <style><class name="x3d-dim"/></style>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>

                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>
